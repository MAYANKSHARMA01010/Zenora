SERVER_PORT=5001
NODE_ENV=development
# NODE_ENV=production
# For Production

# Frontend URLs
FRONTEND_LOCAL_URL=http://localhost:3000
FRONTEND_SERVER_URL=

# Backend URLs
BACKEND_LOCAL_URL=http://localhost:5001
BACKEND_SERVER_URL=

# Database URL
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require

# JWT Session Data
JWT_SESSION_SECRET=replace-with-session-secret
JWT_SESSION_EXPIRES_IN=15M

# JWT Refresh Data
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_REFRESH_EXPIRES_IN=7D